<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal"
        android:background="@color/black">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Test Flows"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APPLICATION ID"
            android:textColor="@color/gray_600"
            android:textSize="11sp"
            android:letterSpacing="0.06"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="Application ID"
            app:boxCornerRadiusBottomEnd="0dp"
            app:boxCornerRadiusBottomStart="0dp"
            app:boxCornerRadiusTopEnd="0dp"
            app:boxCornerRadiusTopStart="0dp"
            app:boxStrokeColor="@color/black"
            app:hintTextColor="@color/gray_600">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_loan_reference"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="All test flows below use this application ID. Leave blank to test SDK error handling."
            android:textColor="@color/gray_600"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_200" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIRECT SDK CALLS"
                android:textColor="@color/black"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="10dp"
                android:text="No docked button — launches a single SDK screen directly."
                android:textColor="@color/gray_600"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_direct_audio"
                style="@style/Widget.ManualKotlinClient.FlatButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Record audio" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_direct_business"
                style="@style/Widget.ManualKotlinClient.FlatButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Business photos" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_direct_collateral"
                style="@style/Widget.ManualKotlinClient.FlatButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Collateral photos" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_direct_family"
                style="@style/Widget.ManualKotlinClient.FlatButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Family photos" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:background="@color/gray_200" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FLOW BUILDER"
                android:textColor="@color/black"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="12dp"
                android:text="Build any multi-step flow. Tap a step to change it. Tap the connector between steps to choose direct SDK or via client screen."
                android:textColor="@color/gray_600"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/flow_builder_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_flow_builder_add_step"
                    style="@style/Widget.ManualKotlinClient.FlatButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="+ Add step" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_flow_builder_run"
                    style="@style/Widget.ManualKotlinClient.FlatButtonFilled"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="▶  Run flow" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp"
                android:background="@color/gray_200" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DOCKED BUTTON — VISIBILITY"
                android:textColor="@color/black"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.06" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="10dp"
                android:text="Test visible=false — the button container should be completely hidden."
                android:textColor="@color/gray_600"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_hidden_docked_button"
                style="@style/Widget.ManualKotlinClient.FlatButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Audio with hidden docked button (visible=false)" />

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
