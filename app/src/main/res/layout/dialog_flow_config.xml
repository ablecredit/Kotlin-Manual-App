<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_sdk_dialog_header"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="22dp"
            android:paddingEnd="24dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.02"
                android:text="Start Loan Flow"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:alpha="0.9"
                android:text="Configure the guided SDK flow and pick which steps to run."
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/sdk_dialog_surface"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:letterSpacing="0.06"
                android:text="STARTING POINT"
                android:textAllCaps="true"
                android:textColor="@color/sdk_dialog_muted"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_start_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mode_new_loan"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="New loan"
                    android:textColor="@color/black"
                    app:strokeColor="@color/sdk_dialog_accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_mode_existing_loan"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Existing loan"
                    android:textColor="@color/black"
                    app:strokeColor="@color/sdk_dialog_accent" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- New loan fields -->
            <LinearLayout
                android:id="@+id/section_new_loan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Application ID"
                    app:boxBackgroundColor="@color/sdk_dialog_field_fill"
                    app:boxStrokeColor="@color/sdk_dialog_accent"
                    app:hintTextColor="@color/sdk_dialog_accent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_loan_reference"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/sdk_dialog_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Product"
                    app:boxBackgroundColor="@color/sdk_dialog_field_fill"
                    app:boxStrokeColor="@color/sdk_dialog_accent"
                    app:endIconTint="@color/sdk_dialog_accent"
                    app:hintTextColor="@color/sdk_dialog_accent">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/act_product"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/sdk_dialog_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_product"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="-4dp"
                    android:minHeight="0dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="+ Add product"
                    android:textColor="@color/sdk_dialog_accent"
                    android:textSize="12sp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Business model"
                    app:boxBackgroundColor="@color/sdk_dialog_field_fill"
                    app:boxStrokeColor="@color/sdk_dialog_accent"
                    app:endIconTint="@color/sdk_dialog_accent"
                    app:hintTextColor="@color/sdk_dialog_accent">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/act_business_model"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/sdk_dialog_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_business_model"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="-4dp"
                    android:minHeight="0dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="+ Add business model"
                    android:textColor="@color/sdk_dialog_accent"
                    android:textSize="12sp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="User name"
                    app:boxBackgroundColor="@color/sdk_dialog_field_fill"
                    app:boxStrokeColor="@color/sdk_dialog_accent"
                    app:hintTextColor="@color/sdk_dialog_accent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_user_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="@color/sdk_dialog_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Branch name"
                    app:boxBackgroundColor="@color/sdk_dialog_field_fill"
                    app:boxStrokeColor="@color/sdk_dialog_accent"
                    app:hintTextColor="@color/sdk_dialog_accent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_branch_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/sdk_dialog_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Existing loan field -->
            <LinearLayout
                android:id="@+id/section_existing_loan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Application ID (existing)"
                    app:boxBackgroundColor="@color/sdk_dialog_field_fill"
                    app:boxStrokeColor="@color/sdk_dialog_accent"
                    app:hintTextColor="@color/sdk_dialog_accent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_existing_loan_reference"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/sdk_dialog_on_surface" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="14dp"
                android:background="@color/sdk_dialog_divider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Steps and order are set app-wide in Profile → Flow config."
                android:textColor="@color/sdk_dialog_muted"
                android:textSize="12sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp" />

        </LinearLayout>

        <!-- Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/sdk_dialog_button_bar_bg"
            android:gravity="end"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_flow_cancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="@color/sdk_dialog_muted" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_flow_start"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Start flow"
                app:backgroundTint="@color/sdk_dialog_accent" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
