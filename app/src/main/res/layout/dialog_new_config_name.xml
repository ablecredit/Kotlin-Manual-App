<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="8dp"
    android:paddingEnd="20dp"
    android:paddingBottom="8dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_new_config_name"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/sdk_config_new_config_hint"
        app:boxBackgroundColor="@color/sdk_dialog_field_fill"
        app:boxStrokeColor="@color/sdk_dialog_accent"
        app:hintTextColor="@color/sdk_dialog_accent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_new_config_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:textColor="@color/sdk_dialog_on_surface" />
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
