<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_sdk_dialog_header"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New loan"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="How would you like to proceed?"
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_loan_only"
            style="@style/Widget.ManualKotlinClient.FlatButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Create loan case only" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_and_run_flow"
            style="@style/Widget.ManualKotlinClient.FlatButtonFilled"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="Create &amp; run full flow" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_choice_cancel"
            style="@style/Widget.ManualKotlinClient.FlatButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:text="Cancel" />
    </LinearLayout>
</LinearLayout>
