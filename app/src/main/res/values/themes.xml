<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.ManualKotlinClient" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
    </style>

    <style name="Theme.ManualKotlinClient" parent="Base.Theme.ManualKotlinClient" />

    <style name="ThemeOverlay.SdkConfigDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="buttonBarStyle">@style/Widget.SdkConfigDialog.ButtonBar</item>
        <item name="android:buttonBarStyle">@style/Widget.SdkConfigDialog.ButtonBar</item>
    </style>

    <style name="Widget.SdkConfigDialog.ButtonBar" parent="Widget.AppCompat.ButtonBar.AlertDialog">
        <item name="android:background">@drawable/bg_sdk_dialog_button_bar</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.ManualKotlinClient.FlatButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="strokeColor">@color/black</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="rippleColor">@color/gray_200</item>
        <item name="cornerRadius">0dp</item>
    </style>

    <style name="Widget.ManualKotlinClient.FlatButtonFilled" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="backgroundTint">@color/black</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">@color/gray_800</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
    </style>
</resources>
